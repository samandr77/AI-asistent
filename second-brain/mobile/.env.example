EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_RC_IOS_KEY=appl_...
EXPO_PUBLIC_RC_ANDROID_KEY=goog_...
EXPO_PUBLIC_WEB_URL=https://your-app.expo.app

# OAuth — Google Sign In
# Obtain from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Web client ID: used on both platforms for Supabase token exchange
# iOS client ID: native Google Sign In on iOS (bundle ID must match app.json ios.bundleIdentifier)
# Apple Sign In requires no mobile env var — configured only in Supabase dashboard
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
