{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export --platform web",
    "preview:ios": "eas build --platform ios --profile preview",
    "preview:android": "eas build --platform android --profile preview",
    "release:ios": "eas build --platform ios --profile production",
    "release:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-google-signin/google-signin": "^14.0.2",
    "@sentry/react-native": "~6.14.0",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.15.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~7.2.4",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~13.0.2",
    "expo-dev-client": "~6.0.20",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~14.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-mmkv": "^4.3.1",
    "react-native-purchases": "^9.15.2",
    "react-native-purchases-ui": "^9.15.2",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-jest": "^29.7.0",
    "eas-cli": "^16.13.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@react-native-google-signin/.*|expo-apple-authentication|expo-crypto|expo-web-browser)"
    ],
    "moduleNameMapper": {
      "^expo-crypto$": "<rootDir>/__mocks__/expo-crypto.ts",
      "^expo-apple-authentication$": "<rootDir>/__mocks__/expo-apple-authentication.ts",
      "^@react-native-google-signin/google-signin$": "<rootDir>/__mocks__/@react-native-google-signin/google-signin.ts",
      "^expo-web-browser$": "<rootDir>/__mocks__/expo-web-browser.ts",
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.ts",
      "^react-native-purchases$": "<rootDir>/__mocks__/react-native-purchases.ts",
      "^react-native-purchases-ui$": "<rootDir>/__mocks__/react-native-purchases.ts",
      "^../services/api$": "<rootDir>/__mocks__/services/api.ts",
      "^../../services/api$": "<rootDir>/__mocks__/services/api.ts",
      "^./api$": "<rootDir>/__mocks__/services/api.ts"
    }
  },
  "private": true
}
