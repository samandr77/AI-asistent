# Copy to .env.telegram-local and fill real values:
# cp .env.telegram-local.example .env.telegram-local
#
# Run:
# docker compose --env-file .env.telegram-local -f docker-compose.telegram-local.yml up --build

# Required because backend still uses Supabase as the source of truth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI providers. For pure UI/auth smoke tests, only placeholders are needed until
# you submit a real dump that reaches the AI parser.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.vibecode-claude.online
OPENAI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Local ports exposed to your browser.
VITE_API_URL=http://localhost:8000
TELEGRAM_MINIAPP_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Telegram bot. TELEGRAM_BOT_TOKEN is optional for browser dev mode, but required
# for real webhook, Bot API, voice files, reminders, and Stars flows.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=local-webhook-secret
TELEGRAM_DEV_AUTH_ENABLED=true
VITE_TELEGRAM_DEV_MODE=1
VITE_TELEGRAM_DEV_START_PARAM=

# Local secrets.
APP_SESSION_JWT_SECRET=local-app-session-secret-change-me
REVENUECAT_WEBHOOK_SECRET=local-revenuecat-secret
ADMIN_CLEANUP_SECRET=local-admin-secret

# Product defaults.
TELEGRAM_PREMIUM_MONTHLY_STARS=499
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
ENVIRONMENT=development
SENTRY_DSN=
SENTRY_RELEASE=telegram-local
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=telegram-local
