SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_STT_MODEL=openai/whisper-large-v3
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000,https://your-desktop-web-app.example.com

# Observability
SENTRY_DSN=
SENTRY_RELEASE=

# Rate limits / AI budget
DAILY_USER_TOKEN_BUDGET=200000
MAX_AUDIO_SECONDS=180

# Premium / RevenueCat (REVENUECAT_WEBHOOK_SECRET is required — app fails to start if missing)
REVENUECAT_WEBHOOK_SECRET=
ADMIN_CLEANUP_SECRET=
DAILY_FREE_TOKEN_BUDGET=50000
DAILY_PREMIUM_TOKEN_BUDGET=500000
FREE_DAILY_DUMP_LIMIT=10
FREE_MAX_ACTIVE_GOALS=3
FREE_HISTORY_DAYS=30

# Telegram Mini App / bot (required before enabling Telegram routers in production)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINIAPP_URL=https://your-miniapp.example.com
APP_SESSION_JWT_SECRET=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TELEGRAM_PREMIUM_MONTHLY_STARS=499
TELEGRAM_DEV_AUTH_ENABLED=false
